configuration {
    modi: "drun";
    show-icons: true;
    drun-display-format: "{icon}  {name}";
    font: "JetBrainsMono Nerd Font 12";
    fixed-num-lines: false;
    show-match: true;
    case-sensitive: false;
    sort: true;
    sorting-method: "fzf";
    disable-history: false;
    hover-select: true;
    eh: 1;
}
@theme "style"
